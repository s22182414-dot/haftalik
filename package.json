{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-ports.mjs",
    "dev": "concurrently -k --names \"VITE,API\" --prefix-colors \"cyan,green\" \"vite\" \"tsx server.ts\"",
    "build": "vite build",
    "start": "node --experimental-strip-types server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "postinstall": "node -e \"process.env.PUPPETEER_SKIP_CHROMIUM_DOWNLOAD='false'; require('child_process').execSync('npx puppeteer browsers install chrome', {stdio: 'inherit'})\""
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "puppeteer": "^25.0.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.14.2",
    "telegram": "^2.26.22",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
